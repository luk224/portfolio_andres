---

import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
const projects = (await getCollection('projects')).sort((a, b) => a.slug.localeCompare(b.slug))

const navLinks = [
	{ href: '#reel', label: 'Reel' },
	{ href: '#projects', label: 'Projects' },
	{ href: '#demos', label: 'Demos' },
	{ href: '#studies', label: 'Studies' },
	{ href: '#skills', label: 'Skills' },
	{ href: '#about', label: 'About' },
]

const demos = [
	{
		title: 'Vehicle Rigging',
		video: '/Vehicles_Rigging.mp4',
		alt: 'Gameplay and cinematic footage of rigged vehicles running in Unreal Engine',
		description: 'Gameplay and cinematic footage of vehicles I rigged, combining Maya and MotionBuilder for the rig work with implementation in Unreal Engine. Built custom tools for steering, wheel rotation, and suspension physics.',
		tools: [
			{ name: 'Maya', logo: '/logo/maya.webp' },
			{ name: 'Motion Builder', logo: '/logo/mobu.webp' },
			{ name: 'Unreal Engine', logo: '/logo/unreal.webp' },
		],
	},
	{
		title: 'Hair Simulation',
		video: '/Hair_simulation_Seb.mp4',
		alt: 'Gameplay results of a hair simulation system made in Maya and exported to joints',
		description: 'Gameplay results of a hair simulation system made in Maya and exported to joints. Controlling simulation settings and baking it helped the cinematic team achieve the wanted animation and prevent unexpected simulation results in the final product.',
		tools: [{ name: 'Maya', logo: '/logo/maya.webp' }],
	},
	{
		title: 'Procedural Animation in Control Rig',
		video: '/procedural_animation.mp4',
		alt: 'Quadruped Control Rig procedurally adapting its walk to uneven terrain with a bouncing head',
		description: "A complete quadruped procedural animation setup built from scratch in Control Rig. Legs adapt to terrain automatically, and a procedural bounce driven off the walk cycle brings the head to life with zero hand-keyed animation.",
		tools: [{ name: 'Unreal Engine', logo: '/logo/unreal.webp' }],
	},
	{
		title: 'IK Ground Collision in Maya',
		video: '/IK_Collision.mp4',
		alt: 'IK collision system keeping robot legs from clipping through uneven ground',
		description: "A custom IK collision system that keeps the robot's legs from clipping through the ground as the terrain changes.",
		tools: [{ name: 'Maya', logo: '/logo/maya.webp' }],
	},
	{
		title: 'Character Creator Tool',
		video: '/Maya_Character_Creator.mp4',
		alt: 'Character Creator tool browsing and filtering Perforce assets to build a character in Maya',
		description: "A Maya tool that browses and filters every asset live from Perforce, letting riggers and animators assemble and export characters in seconds instead of hunting through depot folders. Built-in skinning utilities speed up weight testing and iteration, keeping artists in a fast, uninterrupted workflow.",
		tools: [
			{ name: 'Maya', logo: '/logo/maya.webp' },
			{ name: 'Python', logo: '/logo/python_logo.webp' },
		],
	},
	{
		title: 'Skinning Picker Tool',
		video: '/Skinning_picker.mp4',
		alt: 'Skinning Picker tool letting a rigger select the matching ROM animation for the body part being skinned',
		description: "A standalone PySide tool that lets riggers jump straight to the Range of Motion (ROM) clip for whichever body part they're currently weighting, instead of scrubbing through unrelated animation. Picking a region isolates its ROM immediately, keeping skinning checks fast and focused.",
		tools: [
			{ name: 'Maya', logo: '/logo/maya.webp' },	
			{ name: 'Python', logo: '/logo/python_logo.webp' },
		],
	},
	{
		title: 'Cinematic Editor Tool',
		video: '/Cinematic_Editor.mp4',
		alt: 'Cinematic Editor tool for manipulating cameras, timeline, and characters inside Maya like Unreal Sequencer',
		description: "A Sequencer-style cinematic tool built entirely on OpenMaya and PySide with custom Maya nodes, letting animators and cinematic artists manipulate cameras, timelines, and characters inside Maya the same way they would in Unreal Sequencer. Built-in Perforce integration keeps scenes tracked and synced live with the Game Editor.",
		tools: [
			{ name: 'Maya', logo: '/logo/maya.webp' },
			{ name: 'Python', logo: '/logo/python_logo.webp' },
		],
	},
]

const imgDims: Record<string, [number, number]> = {
	'edge_portada.webp': [1187, 1584],
	'mindseye_1.webp': [1200, 1600],
	'franceska-goya.webp': [611, 873],
	'blades_of_fire.webp': [1200, 1600],
	'Larian_Studios_Logo_2012.webp': [250, 375],
};
---

<Layout title="Andres Felipe Portfolio">
	<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[60] focus:bg-white focus:text-black focus:px-4 focus:py-2 focus:rounded">Skip to content</a>
	<nav class="fixed top-0 left-0 w-full bg-gradient-to-b from-[#F8F2E7]/100 to-[#F8F2E7]/50 shadow-md z-50">
		  <div class="max-w-screen-xl mx-auto px-6 py-3 md:py-4 text-[#211B12] text-base md:text-xl lg:text-2xl font-medium">
			<div class="flex items-center justify-between gap-4">
				<a href="#reel" class="font-extrabold shrink-0 hover:text-[#E85D2C] transition">AF</a>
				<div class="hidden md:flex flex-wrap justify-end items-center gap-4">
					{navLinks.map(link => (
						<a href={link.href} class="hover:text-[#E85D2C] hover:underline transition nav-link">{link.label}</a>
					))}
					<a href="https://www.linkedin.com/in/andrewsupertramp/" target="_blank" rel="noopener noreferrer" class="text-base lg:text-lg bg-[#C43D12] text-white hover:bg-[#E85D2C] font-medium px-4 py-2 rounded-lg transition whitespace-nowrap">Hire me</a>
				</div>
				<a href="https://www.linkedin.com/in/andrewsupertramp/" target="_blank" rel="noopener noreferrer" class="md:hidden text-base bg-[#C43D12] text-white hover:bg-[#E85D2C] font-medium px-4 py-2 rounded-lg transition whitespace-nowrap shrink-0">Hire me</a>
			</div>
			<div class="md:hidden flex gap-5 mt-3 overflow-x-auto whitespace-nowrap [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
				{navLinks.map(link => (
					<a href={link.href} class="shrink-0 hover:text-[#E85D2C] transition nav-link">{link.label}</a>
				))}
			</div>
		</div>
	</nav>
	<main id="main-content" class="px-2 md:px-4 lg:px-20 mx-auto max-w-screen-xl">
		<section id="reel" class="text-center bg-[#F8F2E7] pt-36 pb-24 md:pt-24">
			<div class="max-w-2xl mx-auto text-left mb-14">
				<h1 class="text-5xl font-extrabold">Andrés Felipe</h1>
				<p class="text-2xl mb-4">Technical Animator / Rigger</p>
				<p class="text-lg text-[#5B5140] mb-6">
					6+ years in the game industry, with professional experience in <span class="font-semibold">Spain</span> and the <span class="font-semibold">UK</span>. Currently open to new opportunities.
				</p>
				<div class="flex flex-wrap items-center gap-4">
					<a href="https://www.linkedin.com/in/andrewsupertramp/" target="_blank" rel="noopener noreferrer" class="inline-block bg-[#C43D12] text-white hover:bg-[#E85D2C] text-lg font-medium px-6 py-3 rounded-lg transition">LinkedIn</a>
					<span class="flex items-center gap-2 text-lg text-[#211B12] select-all">
						fg.andres23@gmail.com
						<a href="mailto:fg.andres23@gmail.com" aria-label="Send email to fg.andres23@gmail.com" title="Send email" class="inline-flex items-center justify-center w-9 h-9 shrink-0 rounded-lg border-2 border-[#C43D12] text-[#C43D12] hover:bg-[#C43D12] hover:text-white transition">
							<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<rect x="2" y="4" width="20" height="16" rx="2"/>
								<path d="m22 6-10 7L2 6"/>
							</svg>
						</a>
					</span>
				</div>
			</div>

			<h2 class="text-center text-3xl md:text-4xl font-bold mb-10">Demo Reel</h2>
			<div class="mx-auto max-w-5xl aspect-video border=none">
				<iframe 
				class="w-full h-full rounded-xl shadow-lg"
				
				src="https://www.youtube.com/embed/eMfcm_q7V80?si=KbWdc0T--wQVgEh5&hl=en"
				title="Demo Reel"
				
				allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
				allowfullscreen>
				</iframe>
			</div>
		</section>
		<section id="projects" aria-label="Participated in projects" class="bg-[#EEE3CE] py-14 px-4 md:px-8">
			<h2 class="text-center text-3xl md:text-4xl font-bold mb-20">Experience <span aria-hidden="true">🦴</span></h2>
				<div class="grid gap-8 md:grid-cols-2 auto-rows-auto">
						{
							projects.map(project => {
								const {slug, data} = project
								const {title, author, description, img, experience, extra} = data
								const {youtube, website} = extra
								return (
									<article class="w-full flex gap-6 flex-wrap bg-white rounded-xl shadow-lg p-6">
										<div class="w-full md:w-60 shrink-0">
										<a href={`/project/${slug}`}class="mb-2 xl:mb-0 transition hover:scale-105 ">
											<img
												transition:name={`img-${slug}`}
												class="h-72 w-auto object-cover rounded"
												src={`/${img}`}
												width={imgDims[img]?.[0]}
												height={imgDims[img]?.[1]}
												loading="lazy"
												decoding="async"
												alt ={title}/>
										</a>
										</div>
										<div class="relative flex flex-col justify-start flex-1">
											<div>
												<a href={`/project/${slug}`}><h3 transition:name={`title-${slug}`} class="mb-1 text-2xl font-bold leading-tight text-[#211B12]">{title}</h3></a>

												<p class="mb-1 text-lg font-medium text-[#5B5140]">{author}</p>
												<p class="mb-4 text-sm text-[#8A7F6A]">{experience}</p>
												<p class="mb-2 text-[#5B5140] max-w-sm">{description} <a href={`/project/${slug}`} class="text-[#211B12] underline decoration-[#8A7F6A] underline-offset-2 hover:decoration-[#C43D12] transition">Read more →</a></p>
											</div>
											<div class="bottom-2 flex gap-4  justify-start">
												<a href={youtube} target="_blank" rel="noopener noreferrer" aria-label="YouTube">
													<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 transition hover:scale-150" viewBox="0 0 24 24" fill="currentColor">
														<path d="M19.615 3.184C21.116 3.464 22.245 4.716 22.5 6.253c.291 1.71.291 5.277.291 5.277s0 3.566-.291 5.277c-.255 1.537-1.384 2.789-2.885 3.069C17.578 20.5 12 20.5 12 20.5s-5.578 0-7.615-.624C2.884 19.596 1.755 18.344 1.5 16.807.961 14.697.961 11.53.961 11.53s0-3.566.291-5.277c.255-1.537 1.384-2.789 2.885-3.069C6.422 1.5 12 1.5 12 1.5s5.578 0 7.615.624zM9.75 15.27l6.25-3.77-6.25-3.77v7.54z"/>
													</svg>
												</a>
												<a href={website} target="_blank" rel="noopener noreferrer" aria-label="Website">
													<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 transition hover:scale-150" fill="none" viewBox="0 0 24 24" stroke="currentColor">
														<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2a10 10 0 100 20 10 10 0 000-20zm0 0c2.5 0 4.5 4.5 4.5 10S14.5 22 12 22s-4.5-4.5-4.5-10S9.5 2 12 2z" />
													</svg>
												</a>
											</div>
										</div>
									</article>
								)
							})
						}
						{
							projects.length % 2 !== 0 && (
								<article class="w-full flex flex-col justify-center items-center text-center gap-4 bg-[#211B12] rounded-xl shadow-lg p-6">
									<h3 class="text-2xl font-bold text-white">Open to new opportunities</h3>
									<p class="text-[#EEE3CE] max-w-sm">Currently looking for my next rigging or technical animation role. Let's talk.</p>
									<a href="https://www.linkedin.com/in/andrewsupertramp/" target="_blank" rel="noopener noreferrer" class="inline-block bg-[#C43D12] text-white hover:bg-[#E85D2C] font-medium px-6 py-3 rounded-lg transition">LinkedIn</a>
								</article>
							)
						}
					</div>
		</section>
		<section id="demos" aria-label="Pipeline and tool demos" class="bg-[#F8F2E7] py-14">
			<h2 class="text-center text-3xl md:text-4xl font-bold mb-16">In Action <span aria-hidden="true">🎬</span></h2>
			<div class="space-y-16 max-w-5xl mx-auto">
				{
					demos.map((demo, index) => (
						<div class={`flex flex-col ${index % 2 === 1 ? 'md:flex-row-reverse' : 'md:flex-row'} items-center gap-8 md:gap-12`}>
							<div class="w-full md:w-1/2 flex justify-center relative">
								<video src={demo.video} aria-label={demo.alt} autoplay muted loop playsinline preload="metadata" width="640" height="360" class="demo-video cursor-zoom-in rounded-xl shadow-lg w-full max-w-md md:max-w-full aspect-video object-cover transition-transform duration-300 hover:scale-[1.02]"></video>
								<div class="absolute bottom-2 right-2 flex gap-1">
									{demo.tools.map(tool => (
										<img src={tool.logo} alt={`Made with ${tool.name}`} title={`Made with ${tool.name}`} width="96" height="96" loading="lazy" decoding="async" class="h-10 w-10 md:h-12 md:w-12 object-contain bg-[#211B12]/80 rounded-md p-1 shadow-md" />
									))}
								</div>
							</div>
							<div class="w-full md:w-1/2 text-center md:text-left">
								<h3 class="text-2xl font-bold text-[#211B12] mb-3">{demo.title}</h3>
								<p class="text-[#5B5140] leading-relaxed">{demo.description}</p>
							</div>
						</div>
					))
				}
			</div>
		</section>
		<section id="studies" aria-label="Education" class="bg-[#EEE3CE] py-14 px-4 md:px-8">
			<h2 class="text-center text-3xl md:text-4xl font-bold mb-10 ">Studies <span aria-hidden="true">🎓</span></h2>
			<div class="space-y-14">
				<!-- Lightbox Academy -->
				<div class="bg-[#FFFFFF] rounded-xl p-6 shadow-lg"> 
					<div class="flex flex-col md:flex-row gap-6 items-start">
						<img src="/logo/lightbox_academy.jpg" alt="Lightbox Academy Logo" width="200" height="200" loading="lazy" decoding="async" class="w-16 h-16 object-contain mt-1" />
						<div>
						<h3 class="text-2xl font-bold text-[#211B12]">Lightbox Academy</h3>
						<p class="text-[#5B5140] mb-1">Professional Rigging Course · 2018 – 2019</p>
						<ul class="list-disc list-inside text-[#8A7F6A] text-sm mb-2">
							<li>Rigs for inorganic and organic characters</li>
							<li>Biped & quadruped rigging</li>
							<li>Topology verification, skinning, facial rig</li>
							<li>Modifiers, MEL & Python scripting</li>
							<li>Procedural Rigging in Maya</li>
						</ul>
						<p class="text-sm text-[#C43D12]">
							<a href="https://lboxacademy.es/animacion/curso-profesional-de-rigging/" target="_blank" rel="noopener">Course Website</a>
						</p>
						<p class="text-sm text-[#8A7F6A] mt-2">Skills: Control Systems, ZBrush, Autodesk Maya, Character Rigging</p>
						</div>
					</div>	
				</div>
				<!-- Universidad Rey Juan Carlos -->
				<div class="bg-[#FFFFFF] rounded-xl p-6 shadow-lg"> 
					<div class="flex flex-col md:flex-row gap-6 items-start">
						<img src="/logo/URJC.jpg" alt="URJC Logo" width="200" height="200" loading="lazy" decoding="async" class="w-16 h-16 object-contain mt-1" />
						<div>
						<h3 class="text-2xl font-bold text-[#211B12]">Universidad Rey Juan Carlos</h3>
						<p class="text-[#5B5140] mb-1">Video Games Design & Development Degree · 2015 – 2019</p>
						<p class="text-sm text-[#8A7F6A]">
							Skills: C#, ZBrush, Substance Painter, Adobe Suite, Unity, Unreal Engine, Autodesk Maya, Character Rigging, JavaScript, C++, HTML
						</p>
						</div>
					</div>
				</div>
				<!-- Udemy Course 1 -->
				<div class="bg-[#FFFFFF] rounded-xl p-6 shadow-lg">
					<div class="flex flex-col md:flex-row gap-6 items-start">
						<img src="/logo/Udemy.webp" alt="Udemy Control Rig Course" width="1476" height="1941" loading="lazy" decoding="async" class="w-16 h-16 object-contain mt-1" />
						<div>
							<h3 class="text-xl font-semibold text-[#211B12]">Control Rig for Unreal Engine 5</h3>
							<p class="text-[#5B5140] mb-1">Instructor: Lincoln Margison</p>
							<p class="text-sm text-[#8A7F6A]">Skills: Control Rig, Unreal Engine, Character Rigging</p>
						</div>
					</div>
				</div>
				<!-- Udemy Course 2 -->
				<div class="bg-[#FFFFFF] rounded-xl p-6 shadow-lg">
					<div class="flex flex-col md:flex-row gap-6 items-start">
						<img src="/logo/Udemy.webp" alt="Udemy Procedural Animation Course" width="1476" height="1941" loading="lazy" decoding="async" class="w-16 h-16 object-contain mt-1" />
						<div>
							<h3 class="text-xl font-semibold text-[#211B12]">Procedural Animation for Humans in Unreal Engine 5</h3>
							<p class="text-[#5B5140] mb-1">Instructor: Lincoln Margison</p>
							<p class="text-sm text-[#8A7F6A]">Skills: Procedural Animation, Unreal Engine, Control Rig</p>
						</div>
					</div>
				</div>
			</div>
		</section>
		<section id="skills" aria-label="Skills" class="bg-[#F8F2E7] py-14">
				<h2 class="text-center text-3xl md:text-4xl font-bold mb-10">Skills <span aria-hidden="true">🧠</span></h2>
				<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6 text-center">
				<div>
					<img src="/logo/unreal.webp" alt="Unreal Engine" width="118" height="118" loading="lazy" decoding="async" class="h-12 w-12 object-contain mx-auto mb-2"/>
					<p class="text-[#211B12]">Unreal Engine</p>
				</div>
				<div>
					<img src="/logo/maya.webp" alt="Autodesk Maya" width="96" height="96" loading="lazy" decoding="async" class="h-12 w-12 object-contain mx-auto mb-2" />
					<p class="text-[#211B12]">Maya</p>
				</div>
				<div>
					<img src="/logo/python_logo.webp" alt="Python" width="96" height="96" loading="lazy" decoding="async" class="h-12 w-12 object-contain mx-auto mb-2" />
					<p class="text-[#211B12]">Python</p>
				</div>
				<div>
					<img src="/logo/mgear.png" alt="mGear" width="114" height="112" loading="lazy" decoding="async" class="h-12 w-12 object-contain mx-auto mb-2"/>
					<p class="text-[#211B12]">mGear</p>
				</div>
				<div>
					<img src="/logo/mobu.webp" alt="MotionBuilder" width="96" height="96" loading="lazy" decoding="async" class="h-12 w-12 object-contain mx-auto mb-2" />
					<p class="text-[#211B12]">Motion Builder</p>
				</div>
				<div>
					<img src="/logo/xSens.webp" alt="xSens" width="96" height="96" loading="lazy" decoding="async" class="h-12 w-12 object-contain mx-auto mb-2" />
					<p class="text-[#211B12]">xSens Mocap</p>
				</div>
				</div>
			<div class="flex flex-wrap justify-center gap-2 max-w-4xl mx-auto px-4 pt-10">
				{
					['Rigging', 'Pipeline Development', 'Tool Creation', 'Autodesk Maya', 'Python', 'PySide', 'mGear', '3D Math', 'Full Body & Facial Rigs', 'Skin Weighting', 'Unreal Engine', 'Control Rig', 'Motion Capture', 'Perforce'].map(tag => (
						<span class="text-sm text-[#211B12] bg-white border border-[#8A7F6A]/40 rounded-full px-3 py-1">{tag}</span>
					))
				}
			</div>
			<div class="text-[#5B5140] text-center max-w-6xl mx-auto px-4 pt-6 leading-relaxed grid md:grid-cols-2 gap-8">
				<p class="mb-4 text-justify leading-relaxed">
					<strong>Technical Artist</strong> with solid experience in <span class="font-semibold text-[#211B12]">rigging</span>, <span class="font-semibold text-[#211B12]">pipeline development</span>, and <span class="font-semibold text-[#211B12]">tool creation</span> for animation and real-time production. Proficient in <span class="font-semibold text-[#211B12]">Autodesk Maya</span>, with strong skills in <span class="font-semibold text-[#211B12]">Python scripting</span>, <span class="font-semibold text-[#211B12]">PySide</span> (Qt for UI development), and <span class="font-semibold text-[#211B12]">mGear</span> for building modular and animator-friendly rigs. Deep understanding of <span class="font-semibold text-[#211B12]">3D mathematics</span> including transforms, matrices, and vector math applied to rigging and animation systems.
				</p>
				<p class="mb-4 text-justify leading-relaxed">
					Skilled in creating <span class="font-semibold text-[#211B12]">full body and facial rigs</span>, and <span class="font-semibold text-[#211B12]">skin weighting</span> for characters, props, and vehicles. Experienced in integrating assets into <span class="font-semibold text-[#211B12]">Unreal Engine</span> with support for <span class="font-semibold text-[#211B12]">Control Rig</span>, Live Link, and <span class="font-semibold text-[#211B12]">motion capture</span> workflows. Experience at developing custom tools to optimize artist workflows across <span class="font-semibold text-[#211B12]">rigging</span>, <span class="font-semibold text-[#211B12]">animation</span>, and <span class="font-semibold text-[#211B12]">cinematics</span> teams. Familiar with production pipelines, <span class="font-semibold text-[#211B12]">version control system</span> (Perforce), and collaborative, cross-disciplinary environments.
				</p>
				</div>
		</section>
		<section id="about" aria-label="About" class="bg-[#EEE3CE] py-14 pb-20">
				<h2 class="text-center text-3xl md:text-4xl font-bold mb-10 flex items-center justify-center gap-4">
					About Me <img src="/me.jpeg" alt="Photo of Andrés Felipe" width="200" height="200" loading="lazy" decoding="async" class="w-28 h-28 rounded-full object-cover shadow" />

				</h2>
				<div class="max-w-3xl mx-auto text-center text-[#211B12]">
				<p class="text-lg text-[#5B5140] mb-6">
					I'm a character rigger and technical artist with professional experience working in Madrid, Spain and Edinburgh, Scotland. I enjoy solving complex problems and developing custom rigs and tools to streamline workflows and support efficient production.
				</p>
