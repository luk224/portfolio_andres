	<div id="video-overlay" class="fixed inset-0 z-40 hidden bg-black/80"></div>
</Layout>

<script>
	function setupVideoExpand() {
		const overlay = document.getElementById('video-overlay');
		if (!overlay) return;

		let expandedVideo: HTMLVideoElement | null = null;

		function collapse() {
			if (!expandedVideo) return;
			expandedVideo.style.cssText = '';
			overlay!.classList.add('hidden');
			expandedVideo = null;
		}

		function expand(video: HTMLVideoElement) {
			if (expandedVideo) collapse();
			video.style.cssText = `
				position: fixed;
				top: 50%;
				left: 50%;
				transform: translate(-50%, -50%);
				width: auto;
				height: auto;
				max-width: 92vw;
				max-height: 92vh;
				object-fit: contain;
				z-index: 50;
			`;
			overlay!.classList.remove('hidden');
			expandedVideo = video;
		}

		document.querySelectorAll<HTMLVideoElement>('.demo-video').forEach((video) => {
			video.addEventListener('click', () => {
				if (expandedVideo === video) {
					collapse();
				} else {
					expand(video);
				}
			});
		});

		overlay.addEventListener('click', collapse);
	}

	setupVideoExpand();
	document.addEventListener('astro:page-load', setupVideoExpand);
</script>

